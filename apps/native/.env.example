# Shared default template. Override `NATIVE_WEB_APP_URL` per platform:
# - iOS simulator: http://localhost:3000
# - Android emulator: http://10.0.2.2:3000
# - Real device: your host LAN URL
NATIVE_APP_ID=com.aiweightcoach.app
NATIVE_APP_NAME=AI Weight Coach
NATIVE_APP_MODE=debug
NATIVE_WEB_APP_URL=http://localhost:3000
NATIVE_RELEASE_WEB_APP_URL=https://example.com
NATIVE_MIN_WEB_APP_VERSION=
NATIVE_RELEASE_UPDATE_URL=
NATIVE_RELEASE_SUPPORT_URL=
